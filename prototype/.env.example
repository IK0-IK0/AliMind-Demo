# Hugging Face API Configuration
# Get your API key from: https://huggingface.co/settings/tokens

# Required: Your Hugging Face API token
REACT_APP_HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Model to use (default: facebook/blenderbot-400M-distill)
# Recommended models:
# - facebook/blenderbot-400M-distill (conversational, fast)
# - facebook/blenderbot-1B-distill (better quality, slower)
# - microsoft/DialoGPT-medium (alternative conversational model)
# - your-username/your-custom-model (if you fine-tuned your own)
REACT_APP_HUGGINGFACE_MODEL_ID=facebook/blenderbot-400M-distill

# Optional: Custom API endpoint (if using a different service)
# REACT_APP_HUGGINGFACE_API_URL=https://api-inference.huggingface.co/models/

# Instructions:
# 1. Copy this file to .env
# 2. Replace the API key with your actual key
# 3. Restart the development server
