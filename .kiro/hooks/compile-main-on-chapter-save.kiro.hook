{
  "enabled": true,
  "name": "Compile Main on Chapter Save",
  "description": "Automatically compiles main.typ whenever introduction.typ or methods.typ is saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "chapters/introduction.typ",
      "chapters/methods.typ"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "typst compile chapters/main.typ"
  }
}